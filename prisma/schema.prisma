generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ═══ CUSTOMERS ═══
model Customer {
  id              String   @id @default(cuid())
  firstName       String
  lastName        String
  email           String   @unique
  phone           String
  password        String
  tempPassword    String?
  passwordChanged Boolean  @default(false)
  vehicleType     String?
  vehicleSpecific String?
  budget          String?
  timeline        String?
  source          String?
  notes           String?  @db.Text
  step            Int      @default(0)
  negotiatedPrice String?
  deliveryDate    String?
  contractSigned  Boolean  @default(false)
  contractDate    DateTime?
  contractData    Json?
  paid            Boolean  @default(false)
  paidDate        DateTime?
  paidAmount      String?
  stripePaymentId String?
  isFleet         Boolean  @default(false)
  fleetCompany    String?
  gofetchClientId String?  @unique
  anonymousEmail  String?  @unique
  assignedToId    String?
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  utmTerm         String?
  utmContent      String?
  landingPage     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  assignedTo      CRMUser?           @relation("AssignedAdvocate", fields: [assignedToId], references: [id])
  documents       Document[]
  messages        Message[]
  notesLog        Note[]
  deskingOffers   DeskingOffer[]
  outreachCampaigns OutreachCampaign[]
  touchPoints     TouchPoint[]
  aiAlerts        AIAlert[]

  @@map("customers")
}

// ═══ DOCUMENTS ═══
model Document {
  id           String   @id @default(cuid())
  customerId   String
  docType      String
  fileName     String
  originalName String
  mimeType     String
  size         Int
  storagePath  String
  status       String   @default("received")
  uploadedAt   DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("documents")
}

// ═══ MESSAGES ═══
model Message {
  id         String   @id @default(cuid())
  customerId String
  sender     String
  content    String   @db.Text
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("messages")
}

// ═══ NOTES ═══
model Note {
  id         String   @id @default(cuid())
  customerId String
  content    String   @db.Text
  author     String   @default("agent")
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("notes")
}

// ═══ DEALER AUTH ═══
model Dealer {
  id   String @id @default(cuid())
  pin  String @unique
  name String @default("GoFetch Auto")

  @@map("dealers")
}

// ═══ ANALYTICS ═══
model Analytics {
  id        String   @id @default(cuid())
  page      String
  action    String
  data      Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@map("analytics")
}

// ═══ FLEET COMPANY ═══
model FleetCompany {
  id           String   @id @default(cuid())
  name         String
  contactName  String
  contactEmail String   @unique
  contactPhone String
  password     String
  totalOrders  Int      @default(0)
  createdAt    DateTime @default(now())

  @@map("fleet_companies")
}

// ═══ CRM USERS ═══
model CRMUser {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String
  pin         String
  role        String   @default("advocate")
  avatar      String?
  isActive    Boolean  @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions       CRMPermission[]
  activities        CRMActivity[]
  tasks             CRMTask[]
  assignedCustomers Customer[]      @relation("AssignedAdvocate")

  @@map("crm_users")
}

// ═══ CRM PERMISSIONS ═══
model CRMPermission {
  id        String  @id @default(cuid())
  userId    String
  module    String
  canView   Boolean @default(false)
  canCreate Boolean @default(false)
  canEdit   Boolean @default(false)
  canDelete Boolean @default(false)
  canExport Boolean @default(false)

  user CRMUser @relation(fields: [userId], references: [id])

  @@map("crm_permissions")
}

// ═══ CRM ACTIVITY LOG ═══
model CRMActivity {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  details   String?  @db.Text
  ip        String?
  createdAt DateTime @default(now())

  user CRMUser @relation(fields: [userId], references: [id])

  @@map("crm_activities")
}

// ═══ CRM TASKS ═══
model CRMTask {
  id         String   @id @default(cuid())
  userId     String
  title      String
  description String? @db.Text
  dueDate    DateTime?
  customerId String?
  priority   String   @default("normal")
  status     String   @default("open")
  createdAt  DateTime @default(now())

  user CRMUser @relation(fields: [userId], references: [id])

  @@map("crm_tasks")
}

// ═══ DESKING OFFERS ═══
model DeskingOffer {
  id              String   @id @default(cuid())
  customerId      String
  dealershipId    String?
  dealerName      String?
  dealerAddress   String?
  dealerContact   String?
  dealerPhone     String?
  stockNumber     String?
  vin             String?
  isRevealed      Boolean  @default(false)
  vehicleDesc     String?
  msrp            String?
  negotiatedPrice String?
  otdPrice        String?
  savings         String?
  notes           String?  @db.Text
  status          String   @default("pending")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  customer   Customer    @relation(fields: [customerId], references: [id])
  dealership Dealership? @relation(fields: [dealershipId], references: [id])

  @@map("desking_offers")
}

// ═══ DEALERSHIPS ═══
model Dealership {
  id              String   @id @default(cuid())
  name            String
  brand           String?
  address         String?
  city            String?
  state           String?
  zip             String?
  latitude        Float?
  longitude       Float?
  phone           String?
  email           String?
  website         String?
  contactName     String?
  isActive        Boolean  @default(true)
  lastContacted   DateTime?
  responseRate    Float?
  avgResponseTime Float?
  isPreferred     Boolean  @default(false)
  partnerSince    DateTime?
  agreedTerms     Boolean  @default(false)
  preferredTier   String?
  createdAt       DateTime @default(now())

  deskingOffers     DeskingOffer[]
  outreachResponses OutreachResponse[]

  @@map("dealerships")
}

// ═══ OUTREACH CAMPAIGNS ═══
model OutreachCampaign {
  id              String   @id @default(cuid())
  customerId      String
  vehicleDesc     String?
  colorPref       String?
  features        String?  @db.Text
  maxPrice        String?
  radiusMiles     Int?
  brandFilter     String?
  dealersSent     Int      @default(0)
  dealersResponded Int     @default(0)
  status          String   @default("active")
  sentAt          DateTime @default(now())

  customer  Customer           @relation(fields: [customerId], references: [id])
  responses OutreachResponse[]

  @@map("outreach_campaigns")
}

// ═══ OUTREACH RESPONSES ═══
model OutreachResponse {
  id           String   @id @default(cuid())
  campaignId   String
  dealershipId String
  status       String   @default("pending")
  otdPrice     String?
  vin          String?
  stockNumber  String?
  notes        String?  @db.Text
  responseTime Int?
  respondedAt  DateTime?
  createdAt    DateTime @default(now())

  campaign   OutreachCampaign @relation(fields: [campaignId], references: [id])
  dealership Dealership       @relation(fields: [dealershipId], references: [id])

  @@map("outreach_responses")
}

// ═══ LEAD SOURCES ═══
model LeadSource {
  id          String  @id @default(cuid())
  name        String
  type        String
  isActive    Boolean @default(true)
  config      Json?

  @@map("lead_sources")
}

// ═══ WEBHOOK ENDPOINTS ═══
model WebhookEndpoint {
  id        String  @id @default(cuid())
  name      String
  url       String
  secret    String?
  events    Json?
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())

  @@map("webhook_endpoints")
}

// ═══ AI ALERTS ═══
model AIAlert {
  id           String   @id @default(cuid())
  customerId   String
  type         String
  message      String   @db.Text
  triggered    Boolean  @default(false)
  triggeredAt  DateTime?
  autoTextSent Boolean  @default(false)
  createdAt    DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id])

  @@map("ai_alerts")
}

// ═══ AUDIT LOG ═══
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  before    Json?
  after     Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@map("audit_logs")
}

// ═══ TENANT CONFIG ═══
model TenantConfig {
  id             String @id @default(cuid())
  companyName    String @default("GoFetch Auto")
  logoUrl        String?
  primaryColor   String @default("#D4A23A")
  secondaryColor String @default("#0A1628")
  accentColor    String?
  fontDisplay    String @default("Instrument Serif")
  fontBody       String @default("Outfit")
  domain         String?
  favicon        String?
  emailFrom      String?
  smsFrom        String?
  tagline        String?

  @@map("tenant_configs")
}

// ═══ AI LEARNING ═══
model AILearning {
  id          String   @id @default(cuid())
  category    String
  dataPoint   String   @db.Text
  outcome     String?
  feedback    String?
  usedInModel Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@map("ai_learnings")
}

// ═══ AI MODEL VERSIONS ═══
model AIModelVersion {
  id          String   @id @default(cuid())
  category    String
  version     String
  weights     Json?
  accuracy    Float?
  dataPoints  Int      @default(0)
  trainedAt   DateTime @default(now())

  @@map("ai_model_versions")
}

// ═══ TOUCHPOINTS (Attribution) ═══
model TouchPoint {
  id         String   @id @default(cuid())
  customerId String
  sessionId  String?
  channel    String?
  source     String?
  medium     String?
  campaign   String?
  page       String?
  action     String?
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id])

  @@map("touch_points")
}
